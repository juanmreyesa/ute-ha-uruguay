tooling/mitm-ca/
tooling/apk-patched/

# python venvs
client-py/.venv/
ha-integration/.venv/

# node
client-ts/node_modules/
client-ts/dist/

# misc
__pycache__/
*.pyc
.DS_Store
.idea/
.vscode/

